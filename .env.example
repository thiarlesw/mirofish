# LLM para agentes de simulação (formato OpenAI-compatible)
LLM_API_KEY=sua_chave_gemini_aqui
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.0-flash

# Graphiti + Gemini (substitui Zep Cloud)
GEMINI_API_KEY=sua_chave_gemini_aqui
GRAPHITI_LLM_MODEL=gemini-2.0-flash
GRAPHITI_DB_PATH=/app/data/graphiti_db

# Flask
SECRET_KEY=mirofish-secret-key-mude-isso
FLASK_DEBUG=false

# Simulação
OASIS_DEFAULT_MAX_ROUNDS=10
REPORT_AGENT_MAX_TOOL_CALLS=5

# ===== Configuração original (ZEP Cloud) — mantida para compatibilidade =====
# ZEP_API_KEY=your_zep_api_key_here

# ===== LLM acelerador (opcional) =====
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
